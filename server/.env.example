# copy to server/.env.local (dev) or server/.env.production and fill in

# server
PORT=3000
DB_URL=mongodb://127.0.0.1:27017/portfolio
FRONTEND_URL=http://localhost:5173

# auth
JWT_TOKEN=change-me-to-a-long-random-secret

# admin seed (npm run seed:admin)
ADMIN_NAME=Shahariar
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# contact mail (gmail app password)
MAIL_USER=you@gmail.com
MAIL_PASS=your-gmail-app-password
CONTACT_TO=you@gmail.com

# cloudinary (post image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
