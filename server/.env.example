# copy to server/.env.local (dev) or server/.env.production and fill in

# server
PORT=3000
DB_URL=mongodb://127.0.0.1:27017/portfolio
FRONTEND_URL=http://localhost:5173

# auth
JWT_TOKEN=change-me-to-a-long-random-secret

# admin seed (npm run seed:admin)
ADMIN_NAME=Shahariar
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# contact mail (use a Gmail App Password, not your login password)
MAIL_USER=your-gmail@gmail.com
MAIL_PASS=your-16-char-app-password
# inbox that receives contact-form messages (defaults to MAIL_USER if omitted)
MAIL_TO=your-gmail@gmail.com

# cloudinary (post image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
