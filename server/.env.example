# copy to server/.env.local (dev) or server/.env.production and fill in

# server
PORT=3000
DB_URL=mongodb://127.0.0.1:27017/portfolio
FRONTEND_URL=http://localhost:5173

# auth
JWT_TOKEN=change-me-to-a-long-random-secret

# admin seed (npm run seed:admin)
ADMIN_NAME=Shahariar
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# contact mail — SMTP relay (e.g. Mailtrap for testing, or a real transactional
# provider like Mailtrap Sending, SendGrid, Postmark, etc. for production)
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
# inbox that receives contact-form messages
EMAIL_ADDRESS=you@example.com

# cloudinary (post image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
